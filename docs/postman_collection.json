  "item": [
    {
      "name": "00 - Health & Documentation",
      "description": "",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{serverUrl}}/health",
            "description": "Check that the API server is running.",
            "auth": {
              "type": "noauth"
            }
          },
          "response": []
        },
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{serverUrl}}/api-docs",
            "description": "Open API documentation page in browser/Postman.",
            "auth": {
              "type": "noauth"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "01 - Authentication",
      "description": "",
      "item": [
        {
          "name": "Login - Manager",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/login",
            "description": "Login with seeded manager account and save access/refresh tokens.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{managerEmail}}\",\n  \"password\": \"{{managerPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.accessToken) pm.collectionVariables.set(\"accessToken\", json.data.accessToken);",
                  "if (json?.data?.refreshToken) pm.collectionVariables.set(\"refreshToken\", json.data.refreshToken);",
                  "if (json?.data?.user?.id) pm.collectionVariables.set(\"currentUserId\", json.data.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/refresh",
            "description": "Refresh JWT tokens.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.accessToken) pm.collectionVariables.set(\"accessToken\", json.data.accessToken);",
                  "if (json?.data?.refreshToken) pm.collectionVariables.set(\"refreshToken\", json.data.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/me",
            "description": "Get authenticated user profile."
          },
          "response": []
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/change-password",
            "description": "Change authenticated user password. Use carefully because it changes the real password.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Admin@123456\",\n  \"newPassword\": \"Admin@1234567\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        }
      ]
    },
