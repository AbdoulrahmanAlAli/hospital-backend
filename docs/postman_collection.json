  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "serverUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1"
    },
    {
      "key": "managerEmail",
      "value": "manager@hospital.local"
    },
    {
      "key": "managerPassword",
      "value": "Admin@123456"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "currentUserId",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "doctorId",
      "value": ""
    },
    {
      "key": "doctorUserId",
      "value": ""
    },
    {
      "key": "staffId",
      "value": ""
    },
    {
      "key": "staffUserId",
      "value": ""
    },
    {
      "key": "patientId",
      "value": ""
    },
    {
      "key": "patientUserId",
      "value": ""
    },
    {
      "key": "testId",
      "value": ""
    },
    {
      "key": "prescriptionId",
      "value": ""
    },
    {
      "key": "appointmentId",
      "value": ""
    },
    {
      "key": "billingId",
      "value": ""
    },
    {
      "key": "notificationId",
      "value": ""
    },
    {
      "key": "medicineId",
      "value": ""
    },
    {
      "key": "inventoryItemId",
      "value": ""
    },
    {
      "key": "equipmentId",
      "value": ""
    },
    {
      "key": "shiftId",
      "value": ""
